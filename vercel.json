{
  "framework": "nextjs",
  "buildCommand": "npx turbo build --filter=@nutricoach/web",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 8 * * *" },
    { "path": "/api/cron/daily-summary", "schedule": "0 20 * * *" },
    { "path": "/api/cron/weekly-report", "schedule": "0 9 * * 1" }
  ]
}
